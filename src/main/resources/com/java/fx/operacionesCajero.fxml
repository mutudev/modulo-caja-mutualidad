<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane onKeyPressed="#cerrarConTecla" prefHeight="710.0" prefWidth="1134.0" style="-fx-background-color: #ffffff; -fx-border-color: black; -fx-border-width: 1;" xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mutu.modulo_caja.Controllers.OperacionesController">

    <children>
        <Label layoutX="454.0" layoutY="14.0" style="-fx-text-fill: RED;" text="CANCELACIONES">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <ComboBox fx:id="cmbEmpresa" layoutX="169.0" layoutY="65.0" onAction="#traerOperaciones" prefHeight="39.0" prefWidth="863.0" />
        <ComboBox fx:id="cmbOperacion" layoutX="169.0" layoutY="115.0" onAction="#traerOperaciones" prefHeight="39.0" prefWidth="863.0" />

        <!-- Cajero -->
        <Label layoutX="64.0" layoutY="171.0" style="-fx-text-fill: #39577C;" text="CAJERO:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
        </Label>
        <ComboBox fx:id="cmbCajero" layoutX="169.0" layoutY="165.0" onAction="#traerOperaciones" prefHeight="39.0" prefWidth="863.0" />

        <!-- Tabla -->
        <TableView fx:id="tablaOperaciones" layoutX="20.0" layoutY="225.0" onMouseClicked="#detectarClicks" prefHeight="360.0" prefWidth="1082.0" visible="false">
            <columns>
                <TableColumn fx:id="colSocio" prefWidth="118.0" text="SOCIO" />
                <TableColumn fx:id="colNombre" prefWidth="302.0" text="NOMBRE" />
                <TableColumn fx:id="colFecha" prefWidth="183.0" text="FECHA" />
                <TableColumn fx:id="colHora" prefWidth="164.0" text="HORA" />
                <TableColumn fx:id="colOperacion" prefWidth="147.0" text="TIPO" />
            <TableColumn fx:id="colMonto" prefWidth="167.0" text="MONTO" />
            </columns>
        </TableView>
      <Label layoutX="30.0" layoutY="121.0" style="-fx-text-fill: #39577C;" text="OPERACIÓN:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label layoutX="51.0" layoutY="71.0" style="-fx-text-fill: #39577C;" text="EMPRESA:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
        <Button fx:id="btnCancelar" layoutX="615.0" layoutY="617.0" onAction="#verOperacion" prefHeight="47.0" prefWidth="152.0" style="-fx-background-color: #C0392B; -fx-text-fill: white; -fx-font-weight: bold;" text="PROCESAR" />

        <Button fx:id="btnRegistrar" layoutX="399.0" layoutY="617.0" onAction="#cerrarConBoton" prefHeight="47.0" prefWidth="152.0" style="-fx-background-color: #39577C; -fx-text-fill: white; -fx-font-weight: bold;" text="REGRESAR" />
      <TableView fx:id="tableTraslados" layoutX="39.0" layoutY="235.0" onMouseClicked="#detectarClicks" prefHeight="340.0" prefWidth="1056.0" visible="false">
        <columns>
          <TableColumn fx:id="colTrasID" editable="false" prefWidth="102.0" text="ID" />
          <TableColumn fx:id="colTrasUser" editable="false" prefWidth="211.0" text="USUARIO" />
            <TableColumn fx:id="colTrasOrigen" editable="false" prefWidth="211.0" text="ORIGEN" />
            <TableColumn fx:id="colTrasDestino" editable="false" prefWidth="198.0" text="DESTINO" />
            <TableColumn fx:id="colTrasMonto" editable="false" prefWidth="181.0" text="MONTO" />
            <TableColumn fx:id="colTrasFecha" editable="false" prefWidth="152.0" text="FECHA" />
        </columns>
      </TableView>
    </children>
</AnchorPane>
