      <TextField alignment="CENTER_RIGHT" editable="false" layoutX="927.0" layoutY="298.0" prefHeight="39.0" prefWidth="164.0" text="\$1,500.00" />
      <TextField alignment="CENTER_RIGHT" editable="false" layoutX="927.0" layoutY="354.0" prefHeight="39.0" prefWidth="164.0" text="\$1,500.00" />
      <Label fx:id="lblError" alignment="TOP_LEFT" focusTraversable="false" layoutX="728.0" layoutY="498.0" prefHeight="27.0" prefWidth="363.0" style="-fx-text-fill: red;">
         <font>
            <Font size="12.0" />
         </font>
      </Label>
