<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane onKeyPressed="#cerrarConTecla" prefHeight="603.0" prefWidth="1170.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mutu.modulo_caja.Controllers.CreditoController">

    <children>
        <TextField fx:id="txtMonto" layoutX="728.0" layoutY="512.0" onKeyPressed="#pagarCredito" prefHeight="39.0" prefWidth="363.0" />
        <!-- Título -->
        <Label layoutX="400.0" layoutY="14.0" style="-fx-text-fill: #39577C;" text="Abono a Cuenta de Crédito">
         <font>
            <Font name="System Bold" size="24.0" />
         </font></Label>

        <!-- Socio, Nombre, Crédito -->
        <Label layoutX="31.0" layoutY="60.0" prefHeight="27.0" prefWidth="75.0" style="-fx-text-fill: #39577C;" text="Socio:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label fx:id="lblNumSocio" layoutX="92.0" layoutY="61.0" prefHeight="27.0" prefWidth="75.0" text="8995">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label layoutX="171.0" layoutY="60.0" style="-fx-text-fill: #39577C;" text="Nombre:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label fx:id="lblNombre" layoutX="252.0" layoutY="61.0" prefHeight="27.0" prefWidth="426.0" text="JOSE YAEL MEX MONTERO">
         <font>
            <Font name="System Bold" size="16.0" />
         </font></Label>

        <Label layoutX="684.0" layoutY="60.0" style="-fx-text-fill: #39577C;" text="Número de Crédito:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label fx:id="lblCredito" layoutX="859.0" layoutY="59.0" prefHeight="27.0" prefWidth="151.0" text="123456">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>

        <!-- Tabla -->
        <TableView fx:id="tablaCuotas" layoutX="32.0" layoutY="100" prefHeight="239.0" prefWidth="1110.0">
            <columns>
                <TableColumn fx:id="cuota" prefWidth="99.0" text="Cuota" />
                <TableColumn fx:id="fecha" prefWidth="143.0" text="Fecha" />
                <TableColumn fx:id="colcap" prefWidth="178.0" text="Capital" />
                <TableColumn fx:id="ord" prefWidth="144.0" text="Ordinarios" />
                <TableColumn fx:id="colmora" prefWidth="150.0" text="Moratorios" />
                <TableColumn fx:id="coliva" prefWidth="114.0" text="IVA" />
                <TableColumn fx:id="bonif" prefWidth="130.0" text="Bonif" />
                <TableColumn fx:id="tot" prefWidth="151.0" text="Total" />
            </columns>
        </TableView>

        <!-- Datos informativos -->
        <Label fx:id="lblPlazo" layoutX="30.0" layoutY="382.0" style="-fx-text-fill: #39577C;" text="Plazo: 18 meses">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Label>
        <Label fx:id="lblTasa" layoutX="30.0" layoutY="417.0" style="-fx-text-fill: #39577C;" text="Tasa Ordinaria: 2%">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Label>
        <Label fx:id="lblMora" layoutX="30.0" layoutY="456.0" style="-fx-text-fill: #39577C;" text="Tasa Moratoria: 2%">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Label>
        <Label fx:id="lblTipo" layoutX="30.0" layoutY="494.0" style="-fx-text-fill: #39577C;" text="Tipo: Tradicional">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Label>

        <Label layoutX="675.0" layoutY="364.0" style="-fx-text-fill: #39577C;" text="Total 3 Cuotas inmediatas:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label layoutX="700" layoutY="270" text="" />

        <Label layoutX="749.0" layoutY="419.0" style="-fx-text-fill: #39577C;" text="Saldo del Crédito:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label layoutX="700" layoutY="290" text="" />

        <!-- Botones -->
        <Button fx:id="btnCancelar" layoutX="400.0" layoutY="512.0" onAction="#cerrarConBoton" prefWidth="120" style="-fx-background-color: #C0392B; -fx-text-fill: white; -fx-font-weight: bold;" text="Cancelar" />

        <Button fx:id="btnAbonar" layoutX="555.0" layoutY="512.0" prefWidth="120" style="-fx-background-color: #39577C; -fx-text-fill: white; -fx-font-weight: bold;" text="Abonar" />

        <!-- Campo adicional -->

      <Label fx:id="lblCodigo" layoutX="30.0" layoutY="533.0" style="-fx-text-fill: #39577C;" text="Código: TRA1">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>
      <TextField fx:id="txtInmediatas" alignment="CENTER_RIGHT" editable="false" layoutX="927.0" layoutY="357.0" prefHeight="39.0" prefWidth="164.0" />
      <TextField fx:id="txtSaldoCredito" alignment="CENTER_RIGHT" editable="false" layoutX="927.0" layoutY="412.0" prefHeight="39.0" prefWidth="164.0" text="\$1,500.00" />
      <Label fx:id="lblError" alignment="TOP_LEFT" focusTraversable="false" layoutX="728.0" layoutY="498.0" prefHeight="27.0" prefWidth="363.0" style="-fx-text-fill: red;">
         <font>
            <Font size="12.0" />
         </font>
      </Label>
    </children>
</AnchorPane>
