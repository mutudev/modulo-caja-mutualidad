<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane onKeyPressed="#cerrarConTecla" prefHeight="603.0" prefWidth="1230.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mutu.modulo_caja.Controllers.CreditoController">

    <children>
        <TextField fx:id="txtMonto" layoutX="800.0" layoutY="512.0" onKeyPressed="#pagarCredito" prefHeight="39.0" prefWidth="363.0" style="-fx-border-color: black;" />
        <!-- Título -->
        <Label alignment="CENTER" layoutX="2.0" layoutY="14.0" prefHeight="35.0" prefWidth="1230.0" style="-fx-text-fill: #39577C;" text="Abono a Cuenta de Crédito" textAlignment="CENTER">
         <font>
            <Font name="System Bold" size="24.0" />
         </font></Label>

        <!-- Socio, Nombre, Crédito -->
        <Label layoutX="31.0" layoutY="60.0" prefHeight="27.0" prefWidth="75.0" style="-fx-text-fill: #39577C;" text="Socio:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label fx:id="lblNumSocio" layoutX="92.0" layoutY="61.0" prefHeight="27.0" prefWidth="75.0" text="8995">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label layoutX="171.0" layoutY="60.0" style="-fx-text-fill: #39577C;" text="Nombre:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label fx:id="lblNombre" layoutX="252.0" layoutY="61.0" prefHeight="27.0" prefWidth="426.0" text="JOSE YAEL MEX MONTERO">
         <font>
            <Font name="System Bold" size="16.0" />
         </font></Label>

        <Label layoutX="873.0" layoutY="60.0" style="-fx-text-fill: #39577C;" text="Número de Crédito:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label fx:id="lblCredito" layoutX="1051.0" layoutY="60.0" prefHeight="27.0" prefWidth="151.0" text="123456" textAlignment="CENTER">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>

        <!-- Tabla -->
        <TableView fx:id="tablaCuotas" focusTraversable="false" layoutX="32.0" layoutY="100" prefHeight="239.0" prefWidth="1178.0" scaleShape="false" style="-fx-hbar-policy: never;">
            <columns>
                <TableColumn fx:id="cuota" editable="false" prefWidth="99.0" sortable="false" text="Cuota" />
                <TableColumn fx:id="fecha" editable="false" prefWidth="157.0" sortable="false" text="Fecha" />
                <TableColumn fx:id="colcap" editable="false" prefWidth="162.0" sortable="false" text="Capital" />
                <TableColumn fx:id="ord" editable="false" prefWidth="151.0" sortable="false" text="Ordinarios" />
                <TableColumn fx:id="colmora" editable="false" prefWidth="154.0" sortable="false" text="Moratorios" />
                <TableColumn fx:id="coliva" editable="false" prefWidth="127.0" sortable="false" text="IVA" />
                <TableColumn fx:id="bonif" editable="false" prefWidth="126.0" sortable="false" text="Bonif" />
                <TableColumn fx:id="tot" editable="false" prefWidth="201.0" sortable="false" text="Total" />
            </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
        </TableView>

        <!-- Datos informativos -->
        <Label fx:id="lblPlazo" layoutX="30.0" layoutY="382.0" style="-fx-text-fill: #39577C;" text="Plazo: 18 meses">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Label>
        <Label fx:id="lblTasa" layoutX="30.0" layoutY="417.0" style="-fx-text-fill: #39577C;" text="Tasa Ordinaria: 2%">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Label>
        <Label fx:id="lblMora" layoutX="30.0" layoutY="456.0" style="-fx-text-fill: #39577C;" text="Tasa Moratoria: 2%">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Label>
        <Label fx:id="lblTipo" layoutX="30.0" layoutY="494.0" style="-fx-text-fill: #39577C;" text="Tipo: Tradicional">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Label>

        <Label fx:id="lblInmediatas" layoutX="765.0" layoutY="364.0" style="-fx-text-fill: #39577C;">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label layoutX="700" layoutY="270" text="" />

        <Label layoutX="838.0" layoutY="419.0" style="-fx-text-fill: #39577C;" text="Saldo del Crédito:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label layoutX="700" layoutY="290" text="" />

        <!-- Botones -->
        <Button fx:id="btnCancelar" layoutX="444.0" layoutY="512.0" onAction="#cerrarConBoton" prefWidth="143.0" style="-fx-background-color: #C0392B; -fx-text-fill: white; -fx-font-weight: bold;" text="Cancelar" />

        <Button fx:id="btnAbonar" layoutX="617.0" layoutY="512.0" prefHeight="39.0" prefWidth="143.0" style="-fx-background-color: #39577C; -fx-text-fill: white; -fx-font-weight: bold;" text="Abonar" />

        <!-- Campo adicional -->

      <Label fx:id="lblCodigo" layoutX="30.0" layoutY="533.0" style="-fx-text-fill: #39577C;" text="Código: TRA1">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>
      <TextField fx:id="txtInmediatas" alignment="CENTER_RIGHT" editable="false" layoutX="999.0" layoutY="358.0" prefHeight="39.0" prefWidth="164.0" style="-fx-border-color: black;" />
      <TextField fx:id="txtSaldoCredito" alignment="CENTER_RIGHT" editable="false" layoutX="999.0" layoutY="413.0" prefHeight="39.0" prefWidth="164.0" style="-fx-border-color: black;" text="\$1,500.00" />
      <Label fx:id="lblError" alignment="TOP_LEFT" focusTraversable="false" layoutX="801.0" layoutY="491.0" prefHeight="27.0" prefWidth="363.0" style="-fx-text-fill: red;">
         <font>
            <Font size="12.0" />
         </font>
      </Label>
    </children>
</AnchorPane>
