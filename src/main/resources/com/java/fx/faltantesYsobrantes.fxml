<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane onKeyPressed="#cerrarConTecla" prefHeight="514.0" prefWidth="722.0" xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mutu.modulo_caja.Controllers.FalSobController">
   <children>
       <TextField fx:id="txtSaldoFis" layoutX="193.0" layoutY="215.0" onKeyPressed="#realizarAjuste" prefHeight="39.0" prefWidth="485.0" />
       <Label layoutX="133.0" layoutY="30.0" style="-fx-text-fill: #39577C;" text="REGISTRO DE SOBRANTES Y FALTANTES">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <Label layoutX="52.0" layoutY="165.0" style="-fx-text-fill: #39577C;" text="SALDO FINAL:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TextField fx:id="txtSaldoFin" editable="false" layoutX="193.0" layoutY="159.0" prefHeight="39.0" prefWidth="485.0" />
      <Label layoutX="49.0" layoutY="221.0" style="-fx-text-fill: #39577C;" text="SALDO FÍSICO:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label fx:id="lblTipo" alignment="CENTER_RIGHT" layoutX="32.0" layoutY="311.0" prefHeight="27.0" prefWidth="142.0" style="-fx-text-fill: #39577C;">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
       <TextField fx:id="txtAjuste" editable="false" layoutX="193.0" layoutY="305.0" prefHeight="39.0" prefWidth="485.0" />

       <Button fx:id="btnCancelar" layoutX="193.0" layoutY="396.0" onAction="#cerrarConBoton" prefWidth="130.0" style="-fx-background-color: #C0392B; -fx-text-fill: white; -fx-font-weight: bold;" text="CANCELAR" />

       <Button fx:id="btnRegistrar" disable="true" layoutX="422.0" layoutY="396.0" onAction="#procesarAjuste" prefWidth="130.0" style="-fx-background-color: #39577C; -fx-text-fill: white; -fx-font-weight: bold;" text="REGISTRAR" />
      <Label fx:id="lblError" alignment="TOP_LEFT" layoutX="193.0" layoutY="254.0" prefHeight="27.0" prefWidth="485.0" style="-fx-text-fill: red;">
         <font>
            <Font size="12.0" />
         </font>
      </Label>
      <Label layoutX="84.0" layoutY="107.0" style="-fx-text-fill: #39577C;" text="EMPRESA:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TextField fx:id="txtEmpresa" editable="false" layoutX="193.0" layoutY="101.0" prefHeight="39.0" prefWidth="485.0" />
   </children>
</AnchorPane>
