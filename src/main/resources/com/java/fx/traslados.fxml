<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane onKeyPressed="#cerrarConTecla" prefHeight="445.0" prefWidth="780.0" xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mutu.modulo_caja.Controllers.TrasladoController">
   <children>
       <TextField fx:id="txtCantidad" layoutX="232.0" layoutY="252.0" prefHeight="39.0" prefWidth="493.0" />
      <Label layoutX="245.0" layoutY="24.0" style="-fx-text-fill: #39577C;" text="PROCESO DE TRASLADOS">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <Label layoutX="35.0" layoutY="183.0" style="-fx-text-fill: #39577C;" text="TIPO DE TRASLADO:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label layoutX="109.0" layoutY="258.0" style="-fx-text-fill: #39577C;" text="CANTIDAD:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <ComboBox fx:id="cmbTipoTras" layoutX="232.0" layoutY="177.0" prefHeight="39.0" prefWidth="493.0" />

       <Button fx:id="btnCancelar" layoutX="226.0" layoutY="363.0" onAction="#cerrarConBoton" prefWidth="130.0" style="-fx-background-color: #C0392B; -fx-text-fill: white; -fx-font-weight: bold;" text="CANCELAR" />

       <Button fx:id="btnRegistrar" layoutX="436.0" layoutY="363.0" onAction="#trasladar" prefWidth="130.0" style="-fx-background-color: #39577C; -fx-text-fill: white; -fx-font-weight: bold;" text="REGISTRAR" />
      <Label fx:id="lblError" alignment="TOP_LEFT" layoutX="232.0" layoutY="232.0" prefHeight="27.0" prefWidth="493.0" style="-fx-text-fill: red;">
         <font>
            <Font size="12.0" />
         </font>
      </Label>
      <Label layoutX="121.0" layoutY="112.0" style="-fx-text-fill: #39577C;" text="EMPRESA:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TextField fx:id="txtEmpresa" editable="false" layoutX="232.0" layoutY="106.0" prefHeight="39.0" prefWidth="493.0">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </TextField>
   </children>
</AnchorPane>
